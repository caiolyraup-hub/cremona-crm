# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp Cloud API
# Usado na verificacao inicial do webhook pela Meta.
WHATSAPP_VERIFY_TOKEN=

# Usado para validar a assinatura x-hub-signature-256.
WHATSAPP_APP_SECRET=

# Opcional para scripts locais de teste do webhook.
WEBHOOK_BASE_URL=http://localhost:3000

# O token de acesso da API do WhatsApp NAO e global.
# Ele sera salvo por workspace em workspaces.whatsapp_token.

# Stripe
# Obtenha em dashboard.stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret - gerado pelo Stripe CLI ou no painel de webhooks
STRIPE_WEBHOOK_SECRET=

# Price IDs dos planos - criar produtos no Stripe Dashboard e copiar os IDs
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=

# URL base da aplicacao - usada nos redirects do checkout
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Landing page
NEXT_PUBLIC_LOOM_VIDEO_ID=
# ID do video no Loom
# Ex: https://www.loom.com/share/abc123def456
# -> NEXT_PUBLIC_LOOM_VIDEO_ID=abc123def456

NEXT_PUBLIC_SUPPORT_WHATSAPP=
# Numero de suporte no formato 5511XXXXXXXXX

# Meta Conversions API
META_PIXEL_ID=4347614672125743
META_CAPI_ACCESS_TOKEN=

# Vercel Cron - protege o endpoint /api/cron/process-automation-queue
CRON_SECRET=
# Gerar com: openssl rand -hex 32
# Configurar tambem na Vercel em Settings -> Environment Variables

# Automation queue
AUTOMATION_RETRY_BASE_SECONDS=60
AUTOMATION_RETRY_MAX_SECONDS=1800
AUTOMATION_JOB_LEASE_SECONDS=300

# Twilio WhatsApp - server-side, nunca usar NEXT_PUBLIC_
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_CONTENT_SID_NEW_LEAD=
TWILIO_INBOUND_WEBHOOK_URL=
TWILIO_STATUS_CALLBACK_URL=
TWILIO_TEST_TO=
TWILIO_CONFIRM_SEND=
